<script>

    let currentSlide = 0;
    const intervalTime = 5000; // 设置轮播间隔时间为3000毫秒（3秒）
    let autoSlide;
	function showKnowledge(){
        var aiCenterUrl = 'https://ksp.karon.cn/AiPage/?cookies=' + encodeURIComponent(cookies)+"&application=1";
        // 打开新窗口
        var newWindow = window.open(aiCenterUrl, '_blank');

        if (!newWindow) {
            alert('无法打开培训中心，请检查浏览器是否允许弹出窗口！');
        }
    }
    function showSlide(index) {
        const slides = document.querySelectorAll('.carousel-item');
        if (index >= slides.length) {
            currentSlide = 0; // Loop to first slide
        } else if (index < 0) {
            currentSlide = slides.length - 1; // Loop to last slide
        } else {
            currentSlide = index;
        }

        slides.forEach((slide, i) => {
            slide.classList.remove('active');
            slide.style.display = (i === currentSlide) ? 'block' : 'none';
        });
    }

    function moveSlide(direction) {
        showSlide(currentSlide + direction);
    }

    // 自动轮播功能
    function startAutoSlide() {
        autoSlide = setInterval(() => {
            moveSlide(1); // 每隔时间切换到下一张
        }, intervalTime);
    }

    // 停止自动轮播
    function stopAutoSlide() {
        clearInterval(autoSlide);
    }

    // 当鼠标悬停在轮播图上时停止自动轮播
    const carousel = document.querySelector('.carousel');
    carousel.addEventListener('mouseenter', stopAutoSlide);
    carousel.addEventListener('mouseleave', startAutoSlide);

    // 初始化
    showSlide(currentSlide);
    startAutoSlide(); // 启动自动轮播
</script>
